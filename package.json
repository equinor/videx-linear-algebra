{
  "name": "@equinor/videx-linear-algebra",
  "version": "1.0.22",
  "description": "A library with linear algebra used by Videx.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c",
    "prepub": "npm run build",
    "pub": "npm publish --access=public",
    "test": "vitest run",
    "test:watch": "vitest",
    "predocs": "rimraf docs",
    "docs": "typedoc --out docs src",
    "postdocs": "copyfiles images/* docs && copyfiles .nojekyll docs",
    "lint": "eslint --color"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/equinor/videx-linear-algebra.git"
  },
  "keywords": [
    "videx",
    "linear",
    "algebra"
  ],
  "contributors": [
    "Kjerand Pedersen",
    "Tom Kristian Tjemsland"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/equinor/videx-linear-algebra/issues"
  },
  "homepage": "https://github.com/equinor/videx-linear-algebra#readme",
  "devDependencies": {
    "@equinor/videx-vector2": "^1.0.54",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "copyfiles": "^2.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.4",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@equinor/videx-math": "^1.1.8"
  }
}
