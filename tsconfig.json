{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "rootDir": "./src",
    "types": ["node", "jest"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "./dist",
    "target": "es2022",
  },
  "include": ["./src"],
  "exclude": ["node_modules"]
}
