{
  "compilerOptions": {
    "declaration": true,
    "types": ["node"],
    "rootDir": "./src",
    "declarationDir": "./dist",
    "module": "preserve",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "./dist",
    "target": "es2022"
  },
  "include": ["src/*"],
  "exclude": ["node_modules"]
}
